rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      // Temporarily allowing all access as requested by user
      return true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Registro Validation
    function isValidRegistro(data) {
      return data.id is number 
        && data.tarea in ["Línea 1", "Línea 2", "Línea 3", "TK 1", "TK 2", "TK 3"]
        && data.fecha is string
        && data.hora is string
        && data.dato_numerico is number
        && data.cip in ["CIP1", "CIP2", "CIP3"]
        && data.created_at == request.time;
    }

    match /registros/{registroId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidRegistro(request.resource.data)
        && existsAfter(/databases/$(database)/documents/counters/registros);
      
      // Updates and deletes are not explicitly allowed in basic reqs, but implementation might need it for edit
      allow update: if isSignedIn() && isValidRegistro(request.resource.data);
      allow delete: if isSignedIn();
    }

    match /counters/registros {
      allow get: if isSignedIn();
      allow create, update: if isSignedIn() 
        && request.resource.data.count is number
        && (resource == null || request.resource.data.count == resource.data.count + 1);
    }
  }
}
